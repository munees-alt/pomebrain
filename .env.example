# Public application and authenticated workspace data layer.
NEXT_PUBLIC_APP_URL=https://pomebrain.vercel.app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe subscription billing. Price IDs are optional; without them Checkout
# creates the configured recurring plan price inline.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BUILDER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=

# Pomebrain MCP connector runtime values stay server-only.
POMEBRAIN_SUPABASE_URL=
POMEBRAIN_SUPABASE_SERVICE_ROLE_KEY=
# Customer model and build-provider keys are saved per workspace in Supabase
# Vault. There are deliberately no shared OpenAI, Anthropic, GitHub, Vercel,
# Supabase-project, or analytics credentials for tenant execution.
POMEBRAIN_GOOGLE_CLIENT_ID=
POMEBRAIN_GOOGLE_CLIENT_SECRET=
POMEBRAIN_GOOGLE_REDIRECT_URI=
POMEBRAIN_GOOGLE_REFRESH_TOKEN=
